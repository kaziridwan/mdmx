{
  "name": "mdmx-monorepo",
  "private": true,
  "version": "0.3.1",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @mdmx/core build && pnpm --filter @mdmx/provider-github --filter @mdmx/cli --filter @mdmx/editor --filter @mdmx/next build",
    "test": "pnpm --filter @mdmx/core build && pnpm -r test",
    "check": "pnpm --filter @mdmx/core build && pnpm -r typecheck",
    "verify": "sh scripts/check.sh",
    "generate": "sh scripts/generate.sh",
    "dev:next": "sh scripts/dev-next.sh",
    "dev:playground": "sh scripts/dev-playground.sh",
    "clean": "sh scripts/clean.sh"
  },
  "devDependencies": {
    "typescript": "~5.5.4",
    "vitest": "~2.1.9"
  }
}
