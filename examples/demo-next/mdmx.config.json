{
  "components": "components/mdmx/**/*.tsx",
  "contentDir": "content",
  "outDir": ".mdmx",
  "collections": {
    "posts": {
      "dir": "content/posts",
      "fields": {
        "title": { "control": { "type": "text" }, "required": true },
        "status": {
          "control": { "type": "select", "options": ["draft", "published"] },
          "required": true,
          "default": "draft"
        },
        "slug": { "control": { "type": "text" } },
        "description": { "control": { "type": "textarea" } },
        "coverImage": {
          "control": { "type": "image" },
          "description": "Pick from the media library (Browse…)"
        }
      }
    }
  }
}
